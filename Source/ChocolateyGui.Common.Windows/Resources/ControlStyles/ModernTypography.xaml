<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!--
        Overlay typography for a more modern visual rhythm.
        This dictionary is merged after Typography.xaml so keyed styles are intentionally overridden.
    -->

    <system:Double x:Key="BaseFontSize">15</system:Double>
    <system:Double x:Key="BaseLineHeight">22</system:Double>
    <FontFamily x:Key="BaseFontFamily">Segoe UI</FontFamily>

    <Style x:Key="HeaderTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="42" />
        <Setter Property="LineHeight" Value="50" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SubheaderTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="LineHeight" Value="38" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="TitleTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="LineHeight" Value="32" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="TitleComboboxBlockStyle" TargetType="{x:Type ComboBox}">
        <Setter Property="FontWeight" Value="SemiBold" />

        <Style.Resources>
            <Style TargetType="{x:Type ComboBoxItem}">
                <Setter Property="FontWeight" Value="Normal" />
            </Style>
        </Style.Resources>
    </Style>

    <Style x:Key="SubtitleTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="19" />
        <Setter Property="LineHeight" Value="26" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <Style x:Key="SubtitleAltTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="LineHeight" Value="24" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style x:Key="BaseTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{StaticResource BaseFontSize}" />
        <Setter Property="LineHeight" Value="{StaticResource BaseLineHeight}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="BaseAltTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{StaticResource BaseFontSize}" />
        <Setter Property="LineHeight" Value="{StaticResource BaseLineHeight}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="BodyTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{StaticResource BaseFontSize}" />
        <Setter Property="LineHeight" Value="{StaticResource BaseLineHeight}" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style x:Key="CaptionAltTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style x:Key="CaptionTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

</ResourceDictionary>