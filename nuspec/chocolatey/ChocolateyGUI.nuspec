<?xml version="1.0"?>
<package>
  <metadata>
    <id>__PACKAGE_ID__</id>
    <version>$version$</version>
    <title>__PACKAGE_TITLE__</title>
    <authors>__PACKAGE_AUTHORS__</authors>
    <owners>__PACKAGE_OWNERS__</owners>
    <projectUrl>https://github.com/chocolatey/ChocolateyGUI</projectUrl>
    <projectSourceUrl>https://github.com/chocolatey/ChocolateyGUI</projectSourceUrl>
    <packageSourceUrl>https://github.com/chocolatey/ChocolateyGUI/tree/develop/nuspec/chocolatey</packageSourceUrl>
    <iconUrl>https://img.chocolatey.org/nupkg/chocolateyicon.png</iconUrl>
    <licenseUrl>https://raw.githubusercontent.com/chocolatey/ChocolateyGUI/develop/LICENSE.txt</licenseUrl>
    <bugTrackerUrl>https://github.com/chocolatey/ChocolateyGUI/issues</bugTrackerUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <copyright>2017-2023 Chocolatey Software, Inc</copyright>
    <description>
      Package Manager is the company package management tool, providing a GUI on top of the Chocolatey command-line tool.
    </description>
    <summary>A GUI package manager for instrument environments</summary>
    <releaseNotes>
      __RELEASE_NOTES__
    </releaseNotes>
    <tags>instr-pkgmgr chocolatey admin foss semight</tags>
    <dependencies>
      <dependency id="Chocolatey" version="[2.7.0, 2.999.999]" />
      <dependency id="chocolatey-core.extension" version="1.3.3" />
      <dependency id="dotnetfx" version="4.8.0.20190930" />
    </dependencies>
  </metadata>
  <files>
    <file src="chocolateyInstall.ps1" target="tools" />
    <file src="chocolateyUninstall.ps1" target="tools" />
    <file src="helper.ps1" target="tools" />
    <file src="..\..\..\ChocolateyGUI.msi" target="tools" />
    <file src="..\..\..\..\LICENSE.txt" target="legal\LICENSE.txt" />
    <file src="..\..\..\..\CREDITS.md" target="legal\CREDITS.md" />
    <file src="..\..\..\..\CREDITS.json" target="legal\CREDITS.json" />
    <file src="..\..\..\..\CREDITS.pdf" target="legal\CREDITS.pdf" />
    <file src="VERIFICATION.txt" target="tools" />
  </files>
</package>