<?xml version="1.0"?>
<package>
  <metadata>
    <id>__PACKAGE_ID__</id>
    <version>$version$</version>
    <title>__PACKAGE_TITLE__</title>
    <authors>__PACKAGE_AUTHORS__</authors>
    <owners>__PACKAGE_OWNERS__</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <copyright>__PACKAGE_COPYRIGHT__</copyright>
    <description>
      Package Manager is the company package management tool, providing a GUI on top of the Chocolatey command-line tool.
    </description>
    <summary>A GUI package manager for instrument environments</summary>
    <releaseNotes>
      __RELEASE_NOTES__
    </releaseNotes>
    <tags>__PACKAGE_TAGS__</tags>
    <dependencies>
      <dependency id="__WHITELIST_PACKAGE_ID__" version="1.0.0" />
      <dependency id="Chocolatey" version="[2.7.0, 2.999.999]" />
      <dependency id="chocolatey-core.extension" version="1.3.3" />
    </dependencies>
  </metadata>
  <files>
    <file src="chocolateyInstall.ps1" target="tools" />
    <file src="chocolateyUninstall.ps1" target="tools" />
    <file src="helper.ps1" target="tools" />
    <file src="..\..\..\__INSTALLER_FILE_NAME__" target="tools" />
    <file src="..\..\..\..\LICENSE.txt" target="legal\LICENSE.txt" />
    <file src="..\..\..\..\NOTICE" target="legal\NOTICE.txt" />
    <file src="..\..\..\..\CREDITS.md" target="legal\CREDITS.md" />
    <file src="..\..\..\..\CREDITS.json" target="legal\CREDITS.json" />
    <file src="..\..\..\..\CREDITS.pdf" target="legal\CREDITS.pdf" />
    <file src="VERIFICATION.txt" target="tools" />
  </files>
</package>
